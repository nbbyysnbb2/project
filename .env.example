# 豆包 LLM API 配置
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_API_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/responses
DOUBAO_MODEL=doubao-seed-2-0-pro-260215

# 火山引擎知识库配置
VOLCANO_KNOWLEDGE_ENDPOINT=api-knowledgebase.mlp.cn-beijing.volces.com
VOLCANO_API_KEY=your_volcano_api_key
VOLCANO_SERVICE_RESOURCE_ID=your_service_resource_id

# Supabase 配置（备选知识库）
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 扣子工作流配置
COZE_API_TOKEN=your_coze_api_token
COZE_API_BASE=https://api.coze.cn
COZE_WORKFLOW_ID=your_workflow_id
COZE_BOT_ID=your_bot_id

# OSS 配置
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET=your_bucket_name
